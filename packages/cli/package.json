{
  "name": "proplab",
  "version": "0.1.0",
  "description": "Zero-config component lab — discover components, generate props, preview live",
  "type": "module",
  "bin": {
    "proplab": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "cp ../../README.md ./README.md && npm run build"
  },
  "keywords": [
    "react",
    "storybook",
    "components",
    "props",
    "preview",
    "developer-tools",
    "proplab"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phemymii/PropLab.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/phemymii/PropLab#readme",
  "bugs": {
    "url": "https://github.com/phemymii/PropLab/issues"
  },
  "dependencies": {
    "@proplab/core": "0.1.0",
    "@proplab/server": "0.1.0",
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
