{
  "name": "@proplab/server",
  "version": "0.2.1",
  "description": "PropLab local server — API, live preview, and web UI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy:web",
    "copy:web": "rm -rf dist/web && cp -r ../web/dist dist/web",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "vite",
    "preview",
    "proplab",
    "component-lab"
  ],
  "author": "phemymii",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/middie": "^9.3.3",
    "@fastify/static": "^10.1.2",
    "@fastify/websocket": "^11.3.0",
    "@proplab/core": "0.2.1",
    "@vitejs/plugin-react": "^6.0.4",
    "chokidar": "^5.0.0",
    "fastify": "^5.10.0",
    "open": "^11.0.0",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phemymii/proplab.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/phemymii/proplab#readme",
  "bugs": {
    "url": "https://github.com/phemymii/proplab/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
