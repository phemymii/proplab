{
  "name": "@proplab/server",
  "version": "0.1.0",
  "description": "PropLab local server — API, live preview, and web UI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run copy:web",
    "copy:web": "rm -rf dist/web && cp -r ../web/dist dist/web",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/middie": "^9.0.2",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@proplab/core": "0.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.0",
    "open": "^10.1.0",
    "vite": "^6.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phemymii/PropLab.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/phemymii/PropLab#readme",
  "bugs": {
    "url": "https://github.com/phemymii/PropLab/issues"
  }
}
